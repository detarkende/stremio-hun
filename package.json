{
  "name": "stremio-hun",
  "private": true,
  "description": "A Stremio addon for Hungarian content.",
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "dev": "DB_PATH=./tmp/database.sqlite node --import=tsx --watch --env-file-if-exists=.env index.ts",
    "lint:check": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt:check": "oxfmt --check",
    "fmt:fix": "oxfmt",
    "release": "semantic-release",
    "prepare": "husky"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/zod-validator": "^0.7.6",
    "drizzle-orm": "1.0.0-beta.22",
    "hono": "^4.12.9",
    "tmdb-ts": "^2.3.0",
    "tsx": "^4.21.0",
    "undici": "^8.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@standard-schema/spec": "^1.1.0",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260419.1",
    "husky": "^9.1.7",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "semantic-release": "^25.0.3"
  },
  "packageManager": "pnpm@10.10.0",
  "patchedDependencies": {
    "tmdb-ts@2.3.0": "patches/tmdb-ts@2.3.0.patch",
    "undici@8.1.0": "patches/undici@8.1.0.patch"
  }
}
